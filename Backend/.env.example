# ── Backend environment ──────────────────────────────────────────────
# Copy to `.env` for local dev, and set these as environment variables on
# your host (Railway/Render) for production. Do NOT commit the real `.env`.

# Database (Clever Cloud MySQL in production).
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql+pymysql://root:@localhost/dnd

# Public URL of THIS backend (no trailing slash). Used to proxy map images
# past ISPs that block r2.dev. Local: http://localhost:8000. Production: the
# deployed backend URL, e.g. https://your-backend.up.railway.app
PUBLIC_BASE_URL=http://localhost:8000

# Cloudflare R2 (object storage for generated map PNGs).
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=dnd-maps
# Public bucket base URL, no trailing slash.
#  - r2.dev (e.g. https://pub-xxxx.r2.dev): images are auto-proxied through
#    this backend, because many Indonesian ISPs block *.r2.dev.
#  - custom domain (e.g. https://cdn.yoursite.com): images served directly
#    from R2/CDN (free egress). Switch to this once you connect a domain.
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
