# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

PING_MESSAGE="ping pong"

# Backend base URL. Local dev = FastAPI on :8000. In production set this to the
# deployed backend URL (e.g. https://your-backend.up.railway.app) in the host's
# build env. If unset, the app falls back to http://127.0.0.1:8000.
VITE_API_URL=http://127.0.0.1:8000
